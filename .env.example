# Copy to .env and fill in. .env is gitignored and stays server-side.
ANTHROPIC_API_KEY=sk-ant-...

# Neon Postgres connection strings, per role (from the data platform).
# Use the POOLED host (has -pooler in it) for the app. pizza_ro = read-only for
# the /ask query endpoint; pizza_rw = read-write for placing orders + restock.
PIZZA_RO_URL=postgresql://pizza_ro:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require
PIZZA_RW_URL=postgresql://pizza_rw:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require
